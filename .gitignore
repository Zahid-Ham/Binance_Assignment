# ==============================================================================
#                      PYTHON SYSTEM / COMPILED ARTIFACTS
# ==============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
manifest

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# ==============================================================================
#                       VIRTUAL ENVIRONMENTS & DEPENDENCIES
# ==============================================================================
# Virtual environments (venv / pipenv / poetry / conda)
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
pip-log.txt
pip-delete-this-directory.txt

# ==============================================================================
#                          TESTING & PERFORMANCE TOOLS
# ==============================================================================
# Unit test / coverage reports
htmlcov/
.tosca/
.pytest_cache/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.run

# ==============================================================================
#                            IDE / EDITOR WORKSPACES
# ==============================================================================
# JetBrains (PyCharm / IntelliJ IDEA)
.idea/

# Visual Studio Code
.vscode/

# Jupyter Notebook
.ipynb_checkpoints

# Spyder / Rope project settings
.spyderproject
.spyproject
.ropeproject

# ==============================================================================
#                          DIAGNOSTICS & EXECUTION LOGS
# ==============================================================================
# Bot execution log files
logs/
*.log

# ==============================================================================
