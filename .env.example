# ==============================================================================
#                  BINANCE FUTURES API CREDENTIALS
# ==============================================================================
# Your Binance Futures Testnet API Key.
# Obtain this from: https://testnet.binancefuture.com/
BINANCE_API_KEY=

# Your Binance Futures Testnet Secret Key.
# Always keep this secret and never commit this to version control.
BINANCE_SECRET_KEY=

# ==============================================================================
#                      API CONNECTION CONFIGURATION
# ==============================================================================
# The base endpoint URL for API communication.
# Default Testnet Endpoint: https://testnet.binancefuture.com
BASE_URL=https://testnet.binancefuture.com

# Connection timeout duration in seconds for HTTP requests.
TIMEOUT=30

# Maximum number of connection retry attempts on transient network failures.
MAX_RETRIES=3

# Delay duration in seconds between consecutive connection retry attempts.
RETRY_DELAY=2

# ==============================================================================
#                            LOGGING CONFIGURATION
# ==============================================================================
# Minimum logging severity level threshold (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO

# Target output file path to write rotating log traces.
LOG_FILE=logs/trading_bot.log
